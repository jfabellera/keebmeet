# Deployment config for docker-compose.yml (production). Copy to .env on the
# server and fill in. For LOCAL development, use the .env.example inside each
# service directory (backend/, frontend/, bot/) instead — this file is not used
# for local dev.

DOMAIN=example.com

# Public URLs derived from DOMAIN. The backends live under /api on the same
# origin, so there is no CORS. Update the host part to match DOMAIN above.
PUBLIC_WEB_URL=https://example.com
PUBLIC_API_URL=https://example.com/api
PUBLIC_AUTH_URL=https://example.com/api/auth
# Socket.IO connects to the origin and appends /socket.io/ itself, so no path.
PUBLIC_SOCKET_URL=https://example.com

# Database
KEEBMEET_DATABASE_NAME=keebmeet
KEEBMEET_DATABASE_USER=keebmeet
KEEBMEET_DATABASE_PASSWORD=change-me-to-a-strong-password

# App secrets
JWT_ACCESS_SECRET=
AES_ENCRYPTION_KEY=
INTERNAL_API_SECRET=
QR_CODE_KEY=

# Third-party integrations
GCP_API_KEY=
EVENTBRITE_API_KEY=
EVENTBRITE_CLIENT_SECRET=

# Resend — required to send verification & notification emails.
RESEND_API_KEY=

# Cloudflare Turnstile — server-side secret for verifying captcha tokens.
TURNSTILE_SECRET_KEY=

# Cloudflare R2 object storage — used for meetup image uploads.
# R2_JURISDICTION_URL is the S3 API endpoint for your account (no bucket path).
# R2_PUBLIC_BASE_URL is the public base (r2.dev dev domain or custom domain)
# that stored object keys are served from.
# R2_BUCKET is the bucket name (defaults to "keebmeet" if unset).
#
# REQUIRED bucket setup (not created by the app):
#   1. Create the R2 bucket and enable public access (r2.dev or a custom domain).
#   2. Add ONE object-lifecycle rule that expires objects under the "tmp/" prefix
#      after ~1 day. All uploads land under "tmp/<category>/..." and are promoted
#      to their permanent key on save; the rule reaps abandoned uploads for every
#      category (no new rule needed when future image types are added).
R2_ACCESS_KEY_ID=
R2_SECRET_KEY=
R2_JURISDICTION_URL=
R2_PUBLIC_BASE_URL=
R2_BUCKET=

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
# Must match a route in the frontend and your Discord app's OAuth settings.
DISCORD_REDIRECT_URI=https://example.com/auth/discord/callback
