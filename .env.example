# Deployment config for docker-compose.yml (production). Copy to .env on the
# server and fill in. For LOCAL development, use the .env.example inside each
# service directory (backend/, frontend/, bot/) instead — this file is not used
# for local dev.

DOMAIN=example.com

# Public URLs derived from DOMAIN. The backends live under /api on the same
# origin, so there is no CORS. Update the host part to match DOMAIN above.
PUBLIC_WEB_URL=https://example.com
PUBLIC_API_URL=https://example.com/api
PUBLIC_AUTH_URL=https://example.com/api/auth
# Socket.IO connects to the origin and appends /socket.io/ itself, so no path.
PUBLIC_SOCKET_URL=https://example.com

# Database
KEEBMEET_DATABASE_NAME=keebmeet
KEEBMEET_DATABASE_USER=keebmeet
KEEBMEET_DATABASE_PASSWORD=change-me-to-a-strong-password

# App secrets
JWT_ACCESS_SECRET=
AES_ENCRYPTION_KEY=
INTERNAL_API_SECRET=

# Third-party integrations
GCP_API_KEY=
EVENTBRITE_API_KEY=
EVENTBRITE_CLIENT_SECRET=

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
# Must match a route in the frontend and your Discord app's OAuth settings.
DISCORD_REDIRECT_URI=https://example.com/auth/discord/callback
