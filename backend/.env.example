# Local development config. Copy to .env and fill in the blanks:
#   cp .env.example .env
# .env is gitignored — never commit real secrets.

# Server hostnames/ports (localhost for local dev).
KEEBMEET_API_SERVER_HOSTNAME=localhost
KEEBMEET_API_SERVER_PORT=3000
KEEBMEET_AUTH_SERVER_HOSTNAME=localhost
KEEBMEET_AUTH_SERVER_PORT=3001
KEEBMEET_SOCKET_SERVER_HOSTNAME=localhost
KEEBMEET_SOCKET_SERVER_PORT=3002

KEEBMEET_API_URL=http://localhost:3000
KEEBMEET_SOCKET_URL=http://localhost:3002
# Origin allowed by CORS — must match the frontend dev server URL.
KEEBMEET_WEB_URL=http://localhost:5173

# Database — create a local DB/user; migrations build the schema on startup.
KEEBMEET_DATABASE_HOST=localhost
KEEBMEET_DATABASE_PORT=5432
KEEBMEET_DATABASE_NAME=
KEEBMEET_DATABASE_USER=
KEEBMEET_DATABASE_PASSWORD=

# App secrets — generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=
AES_ENCRYPTION_KEY=
INTERNAL_API_SECRET=

# Third-party integrations.
GCP_API_KEY=
EVENTBRITE_API_KEY=
EVENTBRITE_CLIENT_SECRET=

# Resend — required to send verification & notification emails.
RESEND_API_KEY=

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_REDIRECT_URI=http://localhost:5173/auth/discord/callback

TURNSTILE_SECRET_KEY=

# Cloudflare R2 object storage — used for meetup image uploads.
# R2_JURISDICTION_URL is the S3 API endpoint for your account (no bucket path).
# R2_PUBLIC_BASE_URL is the public base (r2.dev dev domain or custom domain)
# that stored object keys are served from.
# R2_BUCKET is the bucket name (defaults to "keebmeet" if unset).
#
# REQUIRED bucket setup (not created by the app):
#   1. Create the R2 bucket and enable public access (r2.dev or a custom domain).
#   2. Add an object-lifecycle rule that expires objects under the "meetups/tmp/"
#      prefix after ~1 day. Uploads land there and are promoted to permanent keys
#      on save; the rule reaps abandoned uploads. Without it, abandoned temp
#      uploads accumulate forever.
R2_ACCESS_KEY_ID=
R2_SECRET_KEY=
R2_JURISDICTION_URL=
R2_PUBLIC_BASE_URL=
R2_BUCKET=