# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit it.

# Discord bot token (Developer Portal → your app → Bot → Reset Token).
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Base URL of the backend API the bot calls to record RSVPs.
KEEBMEET_API_URL=http://localhost:3000

# Shared secret authenticating the bot's calls to the backend.
# Must match INTERNAL_API_SECRET on the backend.
INTERNAL_API_SECRET=your-internal-api-secret-here
